import java.util.LinkedList;
import java.util.Queue;
import java.util.Stack;

public class Cadena {

    private String espacio;
    private boolean esNumerico;


    public Cadena() {
        this.espacio = "";
        this.esNumerico = false;
    }

    public void validaciones(String textoi) {
        String espaciot = "";
        //Validar mayusculas
        textoi = textoi.toLowerCase();
        // Eliminar espacios
        for (int i = 0; i < textoi.length(); i++) {
            char c = textoi.charAt(i);
            if (c != ' ') {
                espaciot+= c;
            }
        }
        this.espacio = espaciot;
        this.esNumero();
    }

    //Validacion para ver si es numero
    private void esNumero() {
        if (this.espacio.length() == 0) {
            this.esNumerico = false;
            return;
        }

        boolean solohayNumeros = true;
        for (int i = 0; i < this.espacio.length(); i++) {
            char c = this.espacio.charAt(i);
            if (c < '0' || c > '9') {
                solohayNumeros = false;
                break;
            }
        }
        this.esNumerico = solohayNumeros;
    }

    //Metodo para dar vuelta a la cadena y ver si es palindromo o capicua
    /*Usamos colas y pilas a la vez para poder comprabar si son iguales
    ya que si usamos el razonamiento de FIFO y LIFO ingresamos una palabra
    y cada caracter se añade a una pila y una columna despues se comparan sacando
    la primera letra que entro de la cola y la ultima que entro de la pila
     */
    public boolean palindromoOcapicua() {
        Stack<Character> pila = new Stack<>();
        Queue<Character> cola = new LinkedList<>();

        //añadimos elemntos a la cola y a la pila
        for (int i = 0; i < this.espacio.length(); i++) {
            char letra = this.espacio.charAt(i);
            pila.push(letra);
            cola.add(letra);
        }

        while (!pila.isEmpty()) {
            if (pila.pop() != cola.poll()) {
                return false;
            }
        }
        return true;
    }

    public boolean getesNumerico() {
        return this.esNumerico;
    }
}
